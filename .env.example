# Chrome Web Store API Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
CWS_CLIENT_ID=your-client-id.apps.googleusercontent.com
CWS_CLIENT_SECRET=your-client-secret
CWS_REFRESH_TOKEN=your-refresh-token

# WordPress.org Credentials
# Create account at: https://wordpress.org/
WP_USERNAME=your-wordpress-username
WP_EMAIL=your-email@example.com
WP_PASSWORD=your-wordpress-password
