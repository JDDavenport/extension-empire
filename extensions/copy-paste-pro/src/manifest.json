{
  "manifest_version": 3,
  "name": "Copy Paste Pro — Enable Copy & Paste Everywhere",
  "version": "1.0.0",
  "description": "Remove copy/paste restrictions on any website. Enable right-click, text selection, and clipboard access everywhere.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-copy-paste": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Toggle Copy Paste Pro on current tab"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
