{
  "manifest_version": 3,
  "name": "Email Finder Pro — LinkedIn Contact Extractor",
  "version": "1.0.0",
  "description": "Find professional email addresses from LinkedIn profiles and company websites. Extract contacts, verify emails, export CSV.",
  "permissions": [
    "storage",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.extensionpay.com/*",
    "https://dns.google/resolve?*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "optional_permissions": [],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
