{
  "manifest_version": 3,
  "name": "YT Analytics Pro \u2014 YouTube Creator Toolkit",
  "version": "1.0.0",
  "description": "Real-time analytics overlay, performance predictor, thumbnail A/B testing, upload timing, competitor tracking, sentiment analysis...",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://studio.youtube.com/*",
    "https://www.youtube.com/*",
    "https://extensionpay.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://studio.youtube.com/*"
      ],
      "js": [
        "lib/ExtPay.js",
        "scripts/content-studio.js"
      ],
      "css": [
        "styles/overlay.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "lib/ExtPay.js",
        "scripts/content-youtube.js"
      ],
      "css": [
        "styles/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}