{
  "manifest_version": 3,
  "name": "Tab Master Pro — Session & Tab Manager",
  "version": "1.0.0",
  "description": "Save sessions, search tabs, suspend inactive tabs, detect duplicates. Power tab management made simple.",
  "permissions": [
    "tabs",
    "storage",
    "tabGroups",
    "alarms",
    "sessions"
  ],
  "optional_permissions": [
    "history"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "save-session": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Save current session"
    },
    "search-tabs": {
      "suggested_key": { "default": "Alt+F" },
      "description": "Search open tabs"
    },
    "suspend-tabs": {
      "suggested_key": { "default": "Alt+M" },
      "description": "Suspend inactive tabs"
    },
    "find-duplicates": {
      "suggested_key": { "default": "Alt+D" },
      "description": "Find duplicate tabs"
    }
  }
}
