{
  "manifest_version": 3,
  "name": "eBay Seller Analytics \u2014 Sales Tracker & Profit Calculator",
  "version": "1.0.0",
  "description": "Analytics overlay for eBay sellers. Track sales, calculate profits, monitor competitors \u2014 all inside Seller Hub.",
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://www.ebay.com/*",
    "https://ebay.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ebay.com/sh/*",
        "https://www.ebay.com/itm/*",
        "https://www.ebay.com/sch/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}